{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "crons": [
    {
      "path": "/api/cron/backup",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/retention",
      "schedule": "30 7 * * *"
    },
    {
      "path": "/api/cron/health",
      "schedule": "*/5 * * * *"
    }
  ]
}
