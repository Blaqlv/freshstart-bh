// Fresh Start Behavioral Health — data model.
// CMS (block-based pages + structured content types) + RBAC users + immutable
// audit log. Portal/PHI models (intake, messaging, documents) are added in their
// own phases; PHI fields will be AES-256 encrypted at the application layer.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // Pooled Neon endpoint for the app runtime.
  url       = env("DATABASE_URL")
  // Direct (non-pooler) endpoint for migrations/introspection — PgBouncer
  // transaction pooling can't run migrations. Falls back to DATABASE_URL if unset.
  directUrl = env("DIRECT_DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Access control
// ---------------------------------------------------------------------------

enum Role {
  ADMINISTRATOR
  CLINICAL_DIRECTOR
  COMPLIANCE_OFFICER
  RECEPTIONIST
  PROVIDER
  BILLING_STAFF
}

enum ContentStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

// Moderation lifecycle for user-submitted content (reviews/testimonials). Kept
// separate from ContentStatus so nothing reaches the public site without an
// explicit staff approval step (A9).
enum ModerationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PageTemplate {
  SERVICE_DETAIL
  GENERAL
}

// Spanish translation progress per CMS page (D3).
enum TranslationStatus {
  NOT_STARTED
  IN_PROGRESS
  NEEDS_REVIEW
  APPROVED
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String
  passwordHash String
  role         Role      @default(RECEPTIONIST)
  active       Boolean   @default(true)
  mfaSecret    String? // populated in the MFA phase
  mfaEnabled   Boolean   @default(false)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  pageVersions     PageVersion[]
  blogPosts        BlogPost[]
  uploads          Media[]
  // Optional link to a public-facing provider profile (for PROVIDER role)
  provider         Provider?         @relation(fields: [providerId], references: [id])
  providerId       String?
  appointmentSlots AppointmentSlot[] // slots this user (PROVIDER) staffs (A6)
}

// ---------------------------------------------------------------------------
// CMS — block-based pages with draft/publish + versioning
// ---------------------------------------------------------------------------

model Page {
  id                String            @id @default(cuid())
  slug              String            @unique
  title             String
  status            ContentStatus     @default(DRAFT)
  // SEO fields
  seoTitle          String?
  seoDescription    String?
  canonicalUrl      String?
  ogImageUrl        String?
  template          PageTemplate      @default(GENERAL)
  hasSidebar        Boolean           @default(false) // GENERAL only; SERVICE_DETAIL renders the sidebar regardless
  // Pointer to the version currently shown to the public
  publishedVersion  Int?
  // Spanish translation workflow status (D3).
  translationStatus TranslationStatus @default(NOT_STARTED)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  versions PageVersion[]

  @@index([status])
}

// Each save creates/updates a version. `blocks` is an ordered array of content
// blocks (hero, richText, faqAccordion, serviceGrid, testimonialCarousel,
// locationCard, teamGrid, ctaBanner) — see src/lib/cms/blocks.ts.
model PageVersion {
  id        String        @id @default(cuid())
  page      Page          @relation(fields: [pageId], references: [id], onDelete: Cascade)
  pageId    String
  version   Int
  status    ContentStatus @default(DRAFT)
  blocks    Json          @default("[]")
  note      String?
  author    User?         @relation(fields: [authorId], references: [id])
  authorId  String?
  createdAt DateTime      @default(now())

  @@unique([pageId, version])
  @@index([pageId])
}

model Media {
  id           String   @id @default(cuid())
  url          String
  alt          String // required for accessibility
  mimeType     String
  width        Int?
  height       Int?
  sizeBytes    Int?
  uploadedBy   User?    @relation(fields: [uploadedById], references: [id])
  uploadedById String?
  createdAt    DateTime @default(now())
}

// ---------------------------------------------------------------------------
// Structured content types
// ---------------------------------------------------------------------------

model Provider {
  id              String        @id @default(cuid())
  slug            String        @unique
  name            String
  credentials     String? // e.g. "MD", "PhD, PA-C"
  title           String? // e.g. "Medical Director"
  bio             String?
  specializations String[]
  languages       String[]
  telehealth      Boolean       @default(false)
  availability    String?
  headshotUrl     String?
  status          ContentStatus @default(DRAFT)
  order           Int           @default(0)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  users User[]
}

model Testimonial {
  id        String        @id @default(cuid())
  quote     String
  author    String
  source    String        @default("Google")
  rating    Int           @default(5)
  status    ContentStatus @default(PUBLISHED)
  order     Int           @default(0)
  createdAt DateTime      @default(now())

  // Moderation pipeline (A9): user-submitted reviews land as PENDING and are
  // only shown publicly once staff set moderation = APPROVED.
  moderation      ModerationStatus @default(PENDING)
  rejectionReason String? // internal only — never shown to the submitter
  originalQuote   String? // preserved when staff use "Edit & Approve"
  moderatedById   String?
  moderatedAt     DateTime?
  ipHash          String? // sha256(ip) of submitter for abuse tracing (A8)

  @@index([moderation])
}

model Service {
  id          String        @id @default(cuid())
  slug        String        @unique
  title       String
  summary     String?
  description String?
  eligibility String[]
  faqs        Json          @default("[]") // [{q,a}]
  status      ContentStatus @default(DRAFT)
  order       Int           @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model Location {
  id         String        @id @default(cuid())
  slug       String        @unique
  name       String
  street     String
  city       String
  state      String
  zip        String
  phone      String?
  blurb      String?
  lat        Float?
  lng        Float?
  // Google Business Profile listing id for this location, so CMS edits can sync
  // to the matching GBP listing (A4). Pulled from the location's Maps URL.
  gbpPlaceId String?
  // JSON array of opening hours rows, used by JSON-LD + GBP sync (A3/A4).
  hours      Json          @default("[]")
  status     ContentStatus @default(PUBLISHED)
  order      Int           @default(0)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  appointmentSlots AppointmentSlot[] // bookable slots at this location (A6)
}

model BlogPost {
  id            String        @id @default(cuid())
  slug          String        @unique
  title         String
  excerpt       String?
  body          String?
  coverImageUrl String?
  status        ContentStatus @default(DRAFT)
  publishedAt   DateTime?
  author        User?         @relation(fields: [authorId], references: [id])
  authorId      String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([status])
}

// ---------------------------------------------------------------------------
// Forms (builder/manager) — submissions land here; PHI encrypted in its phase
// ---------------------------------------------------------------------------

model FormDefinition {
  id        String   @id @default(cuid())
  key       String   @unique // appointment-request | insurance-verification | intake | document-upload
  name      String
  schema    Json     @default("[]") // editable field definitions
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum SubmissionStatus {
  NEW
  IN_PROGRESS
  CONTACTED
  ARCHIVED
}

// A submitted form. The full payload is AES-256-GCM encrypted at the app layer
// (`encryptedPayload`); only non-sensitive metadata is stored in the clear so
// the admin queue is usable without decrypting. Decryption is gated + audited.
model FormSubmission {
  id               String           @id @default(cuid())
  formKey          String // appointment-request | insurance-verification | ...
  status           SubmissionStatus @default(NEW)
  label            String // non-sensitive summary for the queue (e.g. service @ location)
  encryptedPayload String // ciphertext (see src/lib/crypto.ts)
  handledById      String?
  handledAt        DateTime?
  createdAt        DateTime         @default(now())

  @@index([formKey, status])
  @@index([createdAt])
}

// ---------------------------------------------------------------------------
// Incident reporting
// ---------------------------------------------------------------------------

enum IncidentSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum IncidentStatus {
  OPEN
  INVESTIGATING
  RESOLVED
}

model IncidentReport {
  id              String           @id @default(cuid())
  title           String
  category        String?
  description     String
  severity        IncidentSeverity @default(MEDIUM)
  status          IncidentStatus   @default(OPEN)
  reportedById    String?
  reportedByEmail String?
  resolution      String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([status])
  @@index([severity])
}

// ---------------------------------------------------------------------------
// Immutable audit log (append-only; never updated/deleted from the app)
// ---------------------------------------------------------------------------

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  actorEmail String?
  action     String // e.g. "page.publish", "user.create"
  entity     String // e.g. "Page", "User"
  entityId   String?
  metadata   Json?
  ip         String?
  createdAt  DateTime @default(now())

  @@index([entity, entityId])
  @@index([createdAt])
}

// ---------------------------------------------------------------------------
// Patient Portal (Phase 6)
//
// Patients authenticate in a SEPARATE context from staff `User` (own cookie,
// MFA, 15-min idle timeout). Clinical/PHI text fields are AES-256 encrypted at
// the app layer (see src/lib/crypto.ts) — only non-PHI metadata is stored in
// the clear so the portal is usable without decrypting. Do not collect REAL
// patient data in production until the BAA gate (README §Compliance) is met.
// ---------------------------------------------------------------------------

model Patient {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String
  passwordHash String
  mfaSecret    String?
  mfaEnabled   Boolean   @default(false)
  active       Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // SMS / communication consent + preferences (A5, E6, E7). phoneNumber is kept
  // in the clear because it is required to dispatch SMS; everything clinical
  // stays encrypted. preferredLanguage drives EN/ES template selection (E7).
  smsConsentGiven           Boolean   @default(false)
  smsConsentAt              DateTime?
  smsConsentIpHash          String?
  phoneNumber               String?
  phoneVerified             Boolean   @default(false)
  preferredLanguage         String    @default("en")
  smsAppointmentReminders   Boolean   @default(true)
  smsPortalAlerts           Boolean   @default(true)
  emailAppointmentReminders Boolean   @default(true)
  emailPortalAlerts         Boolean   @default(true)
  lastPortalSmsAt           DateTime? // E3 debounce window for portal alerts

  appointments Appointment[]
  threads      MessageThread[]
  refills      RefillRequest[]
  documents    PatientDocument[]
  statements   BillingStatement[]
}

enum AppointmentStatus {
  REQUESTED
  CONFIRMED
  RESCHEDULE_REQUESTED
  CANCELLED
  COMPLETED
}

model Appointment {
  id              String            @id @default(cuid())
  patientId       String
  patient         Patient           @relation(fields: [patientId], references: [id], onDelete: Cascade)
  // Denormalized labels (no hard FK to Provider/Location) keep the portal
  // self-contained; ids are kept for later joins if needed.
  locationId      String?
  locationName    String?
  serviceSlug     String?
  serviceName     String?
  providerName    String?
  scheduledAt     DateTime
  status          AppointmentStatus @default(REQUESTED)
  reasonEncrypted String? // PHI: reason for visit
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([patientId, status])
  @@index([scheduledAt])
}

enum ThreadStatus {
  OPEN
  CLOSED
}

model MessageThread {
  id        String          @id @default(cuid())
  patientId String
  patient   Patient         @relation(fields: [patientId], references: [id], onDelete: Cascade)
  subject   String
  status    ThreadStatus    @default(OPEN)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  messages  PortalMessage[]

  @@index([patientId])
}

enum MessageSender {
  PATIENT
  STAFF
}

model PortalMessage {
  id            String        @id @default(cuid())
  threadId      String
  thread        MessageThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  sender        MessageSender
  senderName    String
  bodyEncrypted String // PHI: message body
  createdAt     DateTime      @default(now())
  readAt        DateTime?

  @@index([threadId])
}

enum RefillStatus {
  REQUESTED
  IN_REVIEW
  APPROVED
  DENIED
}

model RefillRequest {
  id                  String       @id @default(cuid())
  patientId           String
  patient             Patient      @relation(fields: [patientId], references: [id], onDelete: Cascade)
  medicationEncrypted String // PHI
  pharmacyEncrypted   String? // PHI
  notesEncrypted      String? // PHI
  status              RefillStatus @default(REQUESTED)
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  @@index([patientId, status])
}

enum ScanStatus {
  PENDING
  CLEAN
  INFECTED
}

model PatientDocument {
  id         String     @id @default(cuid())
  patientId  String
  patient    Patient    @relation(fields: [patientId], references: [id], onDelete: Cascade)
  fileName   String
  mimeType   String
  sizeBytes  Int
  // Object-storage key (Cloudflare R2). Null until the upload + virus-scan
  // pipeline is wired (Phase 8 / Forms §4); metadata + audit trail exist now.
  storageKey String?
  scanStatus ScanStatus @default(PENDING)
  uploadedAt DateTime   @default(now())
  deletedAt  DateTime? // retention / soft-delete

  @@index([patientId])
}

enum StatementStatus {
  DUE
  PAID
}

model BillingStatement {
  id              String          @id @default(cuid())
  patientId       String
  patient         Patient         @relation(fields: [patientId], references: [id], onDelete: Cascade)
  periodLabel     String
  amountCents     Int
  status          StatementStatus @default(DUE)
  issuedAt        DateTime        @default(now())
  dueAt           DateTime?
  detailEncrypted String? // PHI-adjacent billing line items

  @@index([patientId, status])
}

// ---------------------------------------------------------------------------
// Intake Portal (Phase 7)
//
// The front door for NEW patients before they have portal credentials. A
// separate, pre-credential session (own cookie) supports save-and-resume. The
// entire multi-step payload (demographics, medical/mental-health history,
// insurance, emergency contacts) is AES-256 encrypted as a single JSON blob;
// only the contact email + status are clear so staff can triage. Resume is via
// email + a hashed resume code. Same BAA gate as the Patient Portal applies.
// ---------------------------------------------------------------------------

enum IntakeStatus {
  IN_PROGRESS
  SUBMITTED
}

model IntakeSubmission {
  id              String       @id @default(cuid())
  email           String // contact email — used for resume + staff triage
  status          IntakeStatus @default(IN_PROGRESS)
  currentStep     Int          @default(0)
  dataEncrypted   String // AES-256-GCM JSON of all step answers (PHI)
  resumeTokenHash String // sha256(resume code) for save-and-resume
  signedName      String? // typed electronic signature
  signedAt        DateTime?
  submittedAt     DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  // SMS consent captured at intake for pre-portal patients (A5). preferredLanguage
  // carries the patient's choice into SMS/portal once they have credentials (E7).
  smsConsentGiven   Boolean   @default(false)
  smsConsentAt      DateTime?
  smsConsentIpHash  String?
  phoneNumber       String?
  phoneVerified     Boolean   @default(false)
  preferredLanguage String    @default("en")

  @@index([email])
  @@index([status])
}

// ---------------------------------------------------------------------------
// Public form submission audit log (A2)
//
// Separate from the portal-facing FormSubmission model: an immutable, low-PHI
// record of every public form hit (appointment request, insurance verification,
// contact). IPs are stored ONLY as a sha256 hash; sensitive free-text fields are
// redacted before the payload is written. Retention is enforced by a cron job.
// ---------------------------------------------------------------------------

model PublicFormSubmission {
  id          String   @id @default(cuid())
  formType    String // "appointment_request" | "insurance_verification" | "contact"
  submittedAt DateTime @default(now())
  ipHash      String // sha256(ip) — never the raw IP
  userAgent   String?
  sessionId   String?
  payload     Json // non-PHI metadata only; sensitive fields redacted before write
  status      String   @default("received") // received | processing | complete | rejected | honeypot_triggered
  staffNotes  String?
  createdBy   String? // staff user id if actioned

  @@index([formType, status])
  @@index([submittedAt])
}

// ---------------------------------------------------------------------------
// Appointment booking (A6) — slot-ready schema
//
// AppointmentSlot is forward-compatible with v2.0 self-scheduling; the v1
// appointment request form keeps writing AppointmentRequest with slotId = null
// (manual scheduling). No destructive migration needed when 2.0 ships.
// ---------------------------------------------------------------------------

model AppointmentSlot {
  id          String   @id @default(cuid())
  providerId  String
  locationId  String
  serviceType String
  startTime   DateTime
  endTime     DateTime
  isAvailable Boolean  @default(true)
  bookedBy    String? // Patient.id of the patient who books (v2.0)
  provider    User     @relation(fields: [providerId], references: [id])
  location    Location @relation(fields: [locationId], references: [id])

  requests AppointmentRequest[]

  @@index([providerId])
  @@index([locationId])
  @@index([startTime])
}

model AppointmentRequest {
  id               String           @id @default(cuid())
  patientName      String
  phone            String
  email            String
  locationId       String
  serviceType      String
  preferredContact String
  smsConsent       Boolean          @default(false)
  smsConsentAt     DateTime? // A5: when consent was captured
  smsConsentIpHash String? // A5: sha256(ip) at consent time
  slotId           String? // null = manual scheduling (v1); set = self-scheduled (v2.0)
  status           String           @default("pending")
  notes            String?
  submittedAt      DateTime         @default(now())
  slot             AppointmentSlot? @relation(fields: [slotId], references: [id])

  @@index([status])
  @@index([submittedAt])
}

// ---------------------------------------------------------------------------
// Insurance eligibility automation (v2.2)
// ---------------------------------------------------------------------------

model InsurancePayer {
  id        String  @id @default(cuid())
  name      String
  payerCode String
  isActive  Boolean @default(true)

  @@index([isActive])
}

model VerificationAttempt {
  id               String    @id @default(cuid())
  submittedAt      DateTime  @default(now())
  insurerName      String
  payerCode        String
  resultStatus     String    // "active" | "inactive" | "unknown" | "api_error"
  rawResponseHash  String
  staffReviewed    Boolean   @default(false)
  staffReviewedAt  DateTime?
  staffReviewedBy  String?
  source           String    // "insurance_form" | "intake"
  formSubmissionId String?
  intakeId         String?
  // Never stores member ID or DOB.

  @@index([formSubmissionId])
  @@index([intakeId])
  @@index([resultStatus, staffReviewed])
}
