# Postgres connection. Locally: docker postgres on :5434. Production: Neon pooled URL.
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"
# Direct (non-pooler) connection used only for `prisma migrate` / introspection.
# On Neon this is the same URL with the "-pooler" segment removed and without
# channel_binding=require — PgBouncer transaction pooling can't run migrations.
# Leave blank locally to fall back to DATABASE_URL.
DIRECT_DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"
# 32+ char random secret for signing admin/patient/intake session cookies (openssl rand -hex 32)
AUTH_SECRET="replace-with-a-long-random-secret"
# 32-byte key, base64 or hex (openssl rand -base64 32) for AES-256-GCM field encryption
APP_ENCRYPTION_KEY="replace-with-32-byte-base64-key"

# --- Public site ---
# Canonical origin used by sitemap.xml / robots.txt / canonical URLs.
# Leave unset until a real domain is live (the app falls back to the Vercel
# deployment URL, or localhost in dev). Set it to enable indexing of that domain.
# NEXT_PUBLIC_SITE_URL="https://your-domain.example"

# --- Vercel Cron (nightly backup) ---
# Bearer token Vercel Cron must present to /api/cron/backup (openssl rand -hex 32).
CRON_SECRET="replace-with-a-long-random-secret"

# --- Cloudflare R2 (document storage + encrypted backups) — set before launch ---
# Without these, uploads fall back to an on-disk .uploads/ store (encrypted) for dev.
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET=""
R2_BACKUP_BUCKET=""

# --- Virus scanning — set before accepting real PHI ---
# Preferred: token-gated HTTPS scan service (see clamav-scanner/). Fails closed.
SCAN_API_URL=""
SCAN_API_TOKEN=""
# Alternative: connect straight to clamd over TCP (no auth — keep it private).
# Without any of these, uploads only reject the EICAR test signature.
CLAMAV_HOST=""
CLAMAV_PORT="3310"
# Days a soft-deleted document is retained before the retention cron purges it.
DOC_RETENTION_GRACE_DAYS="30"

# --- Transactional email (Resend HTTP API) — set before launch ---
RESEND_API_KEY=""
# Verified sender + where staff alerts go. Until a domain is verified in Resend,
# onboarding@resend.dev only delivers to the Resend account-owner address.
EMAIL_FROM="Fresh Start Behavioral Health <onboarding@resend.dev>"
STAFF_NOTIFY_EMAIL=""

# --- Rate limiting (Upstash Redis REST) — set before launch (A8) ---
# Sliding-window limiter for public forms. Without these, the limiter fails OPEN
# (allows all requests) so dev/preview stay usable. Create a free Upstash Redis
# DB and copy its REST URL + token.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# --- Telnyx SMS (E1) — set before sending any SMS ---
# Provision a US number + Messaging Profile. Without these, all SMS sends no-op
# (logged as skipped) so nothing breaks pre-launch. The inbound STOP/START webhook
# lives at /api/webhooks/telnyx — point your Telnyx Messaging Profile there.
TELNYX_API_KEY=""
TELNYX_PHONE_NUMBER=""
TELNYX_MESSAGING_PROFILE_ID=""

# --- Google Business Profile sync (A4) — set to push CMS location edits to GBP ---
# OAuth 2.0 credentials with Business Profile API access. Without these, location
# sync no-ops (it never blocks a save). gbpPlaceId on each Location is the GBP
# resource name (locations/{id}).
GOOGLE_GBP_CLIENT_ID=""
GOOGLE_GBP_CLIENT_SECRET=""
GOOGLE_GBP_REFRESH_TOKEN=""

# --- Statuspage (A11) — set to enable auto-incident creation ---
# The public status page (freshstartbhinc.statuspage.io) is read without auth for
# the footer/portal status pill. These are only needed so the /api/cron/health job
# can OPEN an incident after 3 consecutive failed health checks. Without them the
# cron still runs and logs, but does not create incidents.
STATUSPAGE_API_KEY=""
STATUSPAGE_PAGE_ID=""

# --- Analytics (optional) ---
# A GA4 stream (G-LYZ8MP7XFT) was found on the live site alongside GTM; wire only if desired.

# --- EHR / FHIR integration (v2.1) — PRODUCTION VALUES IN VERCEL PRODUCTION ENV ONLY ---
# Read README_HIPAA.md before switching off sandbox. Default mode is "sandbox":
# the app serves synthetic FHIR data and reaches NO real EHR. Set EHR_MODE=production
# ONLY in the Vercel Production environment, and ONLY after BAAs are signed.
# These production values must never live in .env.local or be readable by Preview.
EHR_MODE="sandbox"
EHR_FHIR_BASE_URL=""        # FHIR R4 base, e.g. https://fhir.vendor.com/r4
EHR_OAUTH_TOKEN_URL=""      # OAuth2 token endpoint
EHR_CLIENT_ID=""
EHR_CLIENT_SECRET=""
EHR_FHIR_SCOPE="patient/*.read launch/patient openid"

# --- Insurance eligibility (v2.2) — PRODUCTION VALUES IN VERCEL PRODUCTION ENV ONLY ---
# Read README_HIPAA.md. Default mode is "sandbox": synthetic eligibility results, no real
# payer API is called. Set ELIGIBILITY_MODE=production (Production env only) AND provide a
# vendor + key only after BAAs are signed. Never in .env.local or Preview.
ELIGIBILITY_MODE="sandbox"
ELIGIBILITY_API_VENDOR=""     # "waystar" | "availity" | "eligible"
ELIGIBILITY_API_BASE_URL=""
ELIGIBILITY_API_KEY=""
